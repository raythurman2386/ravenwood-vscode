{
  "name": "ravenwood",
  "displayName": "Ravenwood",
  "description": "A refined emerald forest theme for VSCode",
  "version": "0.3.3",
  "publisher": "RaymondThurman",
  "author": "raythurman2386",
  "homepage": "https://github.com/raythurman2386/ravenwood-vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/raythurman2386/ravenwood-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/raythurman2386/ravenwood-vscode/issues"
  },
  "license": "MIT",
  "icon": "logo.png",
  "keywords": [
    "forest",
    "ravenwood",
    "theme"
  ],
  "galleryBanner": {
    "color": "#2f383e",
    "theme": "dark"
  },
  "categories": [
    "Themes"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "main": "dist/index-client.js",
  "browser": "dist/index-web.js",
  "contributes": {
    "themes": [
      {
        "label": "Ravenwood Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/ravenwood-dark.json"
      },
      {
        "label": "Ravenwood Light",
        "uiTheme": "vs",
        "path": "./themes/ravenwood-light.json"
      }
    ],
    "configuration": {
      "title": "Ravenwood",
      "properties": {
        "ravenwood.darkContrast": {
          "type": "string",
          "default": "medium",
          "description": "Background contrast for the dark variant.",
          "enum": [
            "soft",
            "medium",
            "hard"
          ]
        },
        "ravenwood.lightContrast": {
          "type": "string",
          "default": "medium",
          "description": "Background contrast for the light variant.",
          "enum": [
            "soft",
            "medium",
            "hard"
          ]
        },
        "ravenwood.darkWorkbench": {
          "type": "string",
          "default": "material",
          "description": "Workbench style for the dark variant.",
          "enum": [
            "material",
            "flat",
            "high-contrast"
          ]
        },
        "ravenwood.lightWorkbench": {
          "type": "string",
          "default": "material",
          "description": "Workbench style for the light variant.",
          "enum": [
            "material",
            "flat",
            "high-contrast"
          ]
        },
        "ravenwood.darkCursor": {
          "type": "string",
          "default": "white",
          "description": "The cursor color in the dark variant.",
          "enum": [
            "white",
            "red",
            "orange",
            "yellow",
            "green",
            "aqua",
            "blue",
            "purple"
          ]
        },
        "ravenwood.lightCursor": {
          "type": "string",
          "default": "black",
          "description": "The cursor color in the light variant.",
          "enum": [
            "black",
            "red",
            "orange",
            "yellow",
            "green",
            "aqua",
            "blue",
            "purple"
          ]
        },
        "ravenwood.darkSelection": {
          "type": "string",
          "default": "grey",
          "description": "The background color of selected text in the dark variant.",
          "enum": [
            "grey",
            "red",
            "orange",
            "yellow",
            "green",
            "aqua",
            "blue",
            "purple"
          ]
        },
        "ravenwood.lightSelection": {
          "type": "string",
          "default": "grey",
          "description": "The background color of selected text in the light variant.",
          "enum": [
            "grey",
            "red",
            "orange",
            "yellow",
            "green",
            "aqua",
            "blue",
            "purple"
          ]
        },
        "ravenwood.italicKeywords": {
          "type": "boolean",
          "default": false,
          "description": "Italicize keywords or not."
        },
        "ravenwood.italicComments": {
          "type": "boolean",
          "default": true,
          "description": "Italicize comments or not."
        },
        "ravenwood.diagnosticTextBackgroundOpacity": {
          "type": "string",
          "default": "0%",
          "markdownDescription": "The opacity of the background color of [diagnostic text](https://code.visualstudio.com/updates/v1_52#_error-background-colors).",
          "enum": [
            "0%",
            "12.5%",
            "25%",
            "37.5%",
            "50%"
          ]
        },
        "ravenwood.highContrast": {
          "type": "boolean",
          "default": false,
          "description": "Whether to add an additional border around items across the UI to increase the contrast."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "rimraf dist *.vsix",
    "compile:ts": "tsc",
    "compile:themes": "node dist/hook/generateThemes.js",
    "compile": "npm run clean && npm run compile:ts && npm run compile:themes",
    "package": "vsce package && git checkout -- themes",
    "lint": "biome check",
    "browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. .",
    "prepare": "husky",
    "format": "biome format --write",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "lint-staged": {
    "*.{ts,js,mjs,json,jsonc,md}": "biome check --write"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/node": "26.1.1",
    "@types/vscode": "1.95.0",
    "@vscode/test-web": "^0.0.81",
    "@vscode/vsce": "^3.9.2",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "rimraf": "6.1.3",
    "tsx": "^4.23.1",
    "typescript": "7.0.2"
  }
}
